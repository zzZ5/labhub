DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,server-ip,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-domain.com,http://server-ip
DJANGO_SECURE_COOKIES=False
DJANGO_TIME_ZONE=Asia/Shanghai

POSTGRES_DB=labhub
POSTGRES_USER=labhub
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

STATIC_URL=/static/
MEDIA_URL=/media/
PROTECTED_MEDIA_ROOT=/app/protected_media

ADMIN_EMAIL=baoju_liu@foxmail.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

SITE_NAME=中农雨磷
SITE_DOMAIN=your-domain.com

# Host ports exposed by the production nginx container.
# Defaults avoid common conflicts with an existing system nginx/apache.
NGINX_HTTP_PORT=8088
NGINX_HTTPS_PORT=8443
